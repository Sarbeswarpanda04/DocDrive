# Backend Environment Variables
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/docdrive

# JWT
JWT_SECRET=diTsYelAM6Vu9YEo0ckk3a41jElCTMojFmXwZiOD4idO5yJxmPa/4spe+sePgjVUaeDbu7/T2Aw/gtOcrMBROw==
JWT_EXPIRES_IN=30m

# AES Encryption for face embeddings
ENCRYPTION_SECRET=11db6bd651db0332eea01571fe00d26b

# Backblaze B2
B2_KEY_ID=your-b2-key-id
B2_APPLICATION_KEY=your-b2-application-key
B2_BUCKET_NAME=doc-drive-storage
B2_REGION=eu-central-003
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20

# File Upload
MAX_FILE_SIZE_MB=50

# Frontend URL (for CORS) — comma-separated if multiple Vercel domains
# e.g. https://docdrive.vercel.app,https://docdrive-git-main-user.vercel.app
FRONTEND_URL=http://localhost:3000

# Admin
ADMIN_SETUP_KEY=your-admin-setup-secret-key
